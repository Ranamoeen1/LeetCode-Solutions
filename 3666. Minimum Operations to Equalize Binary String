class Solution:
    def minOperations(self, s: str, k: int) -> int:
        n = len(s)
        odd_count = s.count('0')
        
        if odd_count == 0:
            return 0
        
        even_count = n - odd_count
        
        for m in range((odd_count + k - 1) // k, n + 2):
            total = m * k
            
            if total % 2 != odd_count % 2:
                continue
            
            max_odd_per_zero = m if m % 2 == 1 else m - 1
            max_odd_total = odd_count * max_odd_per_zero
            
            max_even_per_one = m if m % 2 == 0 else m - 1
            max_even_total = even_count * max_even_per_one
            
           
            low = max(odd_count, total - max_even_total)
            high = min(max_odd_total, total)
            
            if low > high:
                continue
            
            if low % 2 != odd_count % 2:
                low += 1
            
            if low <= high:
                return m
        
        return -1
